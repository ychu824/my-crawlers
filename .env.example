# ── King County CPL Appointment PII ───────────────────────────────
# Used by configs/kingcounty_cpl_config.json to fill the QLess kiosk form
CPL_FIRST_NAME=John
CPL_LAST_NAME=Doe
CPL_PHONE=1234567890

# ── SMTP / Email Notifications ────────────────────────────────────
# Gmail example: enable 2FA, then generate an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=your-email@gmail.com

# Where price-drop / appointment alerts are sent (can be any address)
# Comma-separate for multiple recipients: a@gmail.com,b@outlook.com
NOTIFY_EMAIL=your-email@gmail.com

# ── Email Templates (optional) ───────────────────────────────────
# Use {{item}}, {{oldPrice}}, {{newPrice}}, {{message}} as placeholders
# EMAIL_PRICE_SUBJECT=Price alert: {{item}}
# EMAIL_PRICE_BODY={{item}} price dropped from {{oldPrice}} to {{newPrice}}.
# EMAIL_APPT_SUBJECT=Appointment available: {{item}}
# EMAIL_APPT_BODY={{item}} has appointments available!\n\n{{message}}

# ── Tracker Service ───────────────────────────────────────────────
# HTTP port for the tracker API (default: 3001)
TRACKER_PORT=3001

# Python interpreter override (default: python3 or venv if present)
# PYTHON=/usr/bin/python3

# ── Log Garbage Collection ────────────────────────────────────────
# Number of days to keep logs and snapshots (default: 3)
LOG_RETENTION_DAYS=3
