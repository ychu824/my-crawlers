{
    "name": "EVO Skis Crawler",
    "url": "https://www.evo.com/shop/ski/skis",
    "categories": {
        "ski": "https://www.evo.com/shop/ski/skis",
        "skis": "https://www.evo.com/shop/ski/skis",
        "backcountry": "https://www.evo.com/shop/ski/backcountry",
        "snowboard": "https://www.evo.com/shop/snowboard",
        "snowboards": "https://www.evo.com/shop/snowboard",
        "blizzard": "https://www.evo.com/shop/ski/skis/blizzard",
        "atomic": "https://www.evo.com/shop/ski/skis/atomic",
        "fischer": "https://www.evo.com/shop/ski/skis/fischer",
        "nordica": "https://www.evo.com/shop/ski/skis/nordica",
        "black crows": "https://www.evo.com/shop/ski/skis/black-crows",
        "salomon": "https://www.evo.com/shop/ski/skis/salomon"
    },
    "page_param": "page",
    "max_pages": 10,
    "use_playwright": true,
    "wait_for_selector": "a[href^='/skis/'], a[href^='/snowboards/']",
    "items_selector": "a[href^='/skis/'], a[href^='/snowboards/']",
    "fields": {
        "name": {
            "regex": "^(.*?)\\s+\\$"
        },
        "brand": {
            "regex": "^([A-Za-z0-9'\\.\\-]+)"
        },
        "price": {
            "regex": "(\\$[0-9,]+(?:\\.\\d{2})?)(?!.*\\$[0-9,]+(?:\\.\\d{2})?)"
        },
        "link": {
            "attribute": "href"
        }
    }
}
